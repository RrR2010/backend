// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  module   = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============== ENUMS ==============

enum SystemState {
  ACTIVE
  LOCKED
  HIDDEN
}

enum UserScope {
  PLATFORM
  TENANT
}

enum PlatformRole {
  ADMIN
  USER
}

enum TenantRole {
  ADMIN
  USER
}

enum AuthProviderType {
  EMAIL
  CPF
}

// ============== POLYMORPHIC ENUMS ==============

enum OwnerType {
  MemberProfile
  TenantSite
}

enum AddressType {
  HOME
  WORK
  BILLING
  SHIPPING
}

enum PhoneType {
  MOBILE
  HOME
  WORK
  WHATSAPP
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  CPF
  CNPJ
  RG
  PASSPORT
}

enum TenantSiteType {
  FACTORY
  WAREHOUSE
  OFFICE
}

enum RegistrationState {
  PENDING
  APPROVED
  PROVISIONING
  PROVISIONED
  REJECTED
  EXPIRED
}

enum IngredientFunctionType {
  ADDITIVE
  INGREDIENT
}

enum TechnicalInfoSourceType {
  DATASHEET
  IBGE
  LAB_REPORT
  INTERNET
  REGULATORY_TABLE
}

enum FlavorOriginType {
  NOT_APPLICABLE
  NATURAL
  IDENTICAL_TO_NATURAL
  ARTIFICIAL
  NO_FLAVOR
}

enum ColorantOriginType {
  NOT_APPLICABLE
  NATURAL
  IDENTICAL_TO_NATURAL
  SYNTHETIC
  NO_COLORANT
}

enum NutrientUnit {
  G
  MG
  MCG
  KCAL
}

enum NutrientCategory {
  MANDATORY_DECLARATION
  SPECIFIC_CARBS
  FATTY_ACIDS
  MINERALS
  FIBER
  VITAMINS
  OTHER
}

enum AllergenRelationType {
  CONTAINS
  MAY_CONTAIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LabelProfileStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum PlanType {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  GRACE
  PAUSED
  CANCELED
  EXPIRED
}

enum ActionStatus {
  COMPLETED
  SCHEDULED
  CANCELED
  FAILED
}

// ============== TENANT ==============

model Tenant {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  name        String
  slug        String?
  website     String?     @unique
  locale      String
  timezone    String
  language    String
  logoUrl     String?
  settings    Json?

  memberships TenantMembership[]
  sessions    Session[]
  sites       TenantSite[]
  auditLogs   AuditLog[]
  subscription Subscription?

  // Products domain
  products            Product[]
  formulationVersions FormulationVersion[]

  // Ingredient domain
  tenantAllergens     TenantAllergen[]
  tenantNutrients     TenantNutrient[]
  functionalGroups    FunctionalGroup[]
  companies           Company[]
  technicalInfoSources TechnicalInfoSource[]
  ingredients         Ingredient[]
  ingredientAllergens IngredientTenantAllergen[]
  ingredientNutrients IngredientTenantNutrient[]
  ingredientBaseAllergens IngredientBaseAllergen[]
  ingredientBaseNutrients IngredientBaseNutrient[]
  ingredientRegulatoryProfiles IngredientRegulatoryProfile[]
  ingredientLabelingProfiles   IngredientLabelingProfile[]
  ingredientTechnicalProfiles  IngredientTechnicalProfile[]
}

// ============== USER ==============

model User {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  scope       UserScope   @default(TENANT)

  // Relations
  platformMembership PlatformMembership?
  tenantMemberships  TenantMembership[]
  identities         Identity[]
  sessions           Session[]
  auditLogs          AuditLog[]
}

// ============== MEMBERSHIP ==============

model PlatformMembership {
  id            String         @id @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  roles         PlatformRole[] @default([USER])
  memberProfile MemberProfile?
}

model TenantMembership {
  id            String         @id @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  isOwner       Boolean        @default(false)
  roles         TenantRole[]   @default([USER])
  memberProfile MemberProfile?

  @@unique([userId, tenantId])
}

// ============== SESSION ==============

model Session {
  id               String    @id @unique @default(uuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  refreshTokenHash String    @unique
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenHash])
}

// ============== IDENTITY ==============

model Identity {
  id               String           @id @default(uuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  systemState      SystemState      @default(ACTIVE)
  authProviderType AuthProviderType
  identifier       String
  secretHash       String?
  user             User             @relation(fields: [userId], references: [id])
  userId           String

  @@unique([authProviderType, identifier])
  @@index([identifier])
}

// ============== POLYMORPHIC ADDRESS ==============

model Address {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)

  // Polymorphic owner reference
  ownerId   String
  ownerType OwnerType

  // Address fields
  type       AddressType
  street     String
  number     String
  complement String?
  district   String?
  city       String
  state      String
  postalCode String
  country    String      @default("BR")
  isDefault  Boolean     @default(false)

  // Constraints
  @@unique([ownerId, ownerType, type])
  @@index([ownerId, ownerType])
}

// ============== POLYMORPHIC PHONE ==============

model Phone {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)

  // Polymorphic owner reference
  ownerId   String
  ownerType OwnerType

  // Phone fields
  type        PhoneType
  countryCode String    @default("55")
  number      String
  isWhatsapp  Boolean   @default(false)
  isDefault   Boolean   @default(false)

  // Constraints
  @@unique([ownerId, ownerType, type])
  @@index([ownerId, ownerType])
}

// ============== MEMBER PROFILE ==============

model MemberProfile {
  id                   String              @id @unique @default(uuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  systemState          SystemState         @default(ACTIVE)
  externalId           String?
  fullName             String
  displayName          String?
  dateOfBirth          DateTime?
  gender               Gender?
  photoUrl             String?
  locale               String
  timezone             String
  language             String
  platformMembershipId String?             @unique
  platformMembership   PlatformMembership? @relation(fields: [platformMembershipId], references: [id])
  tenantMembershipId   String?             @unique
  tenantMembership     TenantMembership?   @relation(fields: [tenantMembershipId], references: [id])

  documents MemberProfileDocument[]
}

// ============== MEMBER PROFILE DOCUMENT ==============

model MemberProfileDocument {
  id              String        @id @unique @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  systemState     SystemState   @default(ACTIVE)
  memberProfileId String
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id])
  type            DocumentType
  value           String
  normalizedValue String

  @@unique([memberProfileId, type])
}

// ============== AUDIT LOG ==============

model AuditLog {
  id          String   @id @unique @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  entityName  String
  entityId    String
  ipAddress   String?
  userAgent   String?
  action      String
  before      Json?
  after       Json?
  description               String?
  tenantImpersonationId     String?   @map("tenant_impersonation_id")

  @@index([tenantId])
  @@index([userId])
  @@index([entityName])
  @@index([entityId])
  @@index([createdAt])
}

// ============== TENANT REGISTRATION ==============

model TenantRegistration {
  id                    String   @id @default(uuid())
  externalRef           String   @unique
  // Valid values defined in RegistrationState enum (backend/src/shared/enums.ts)
  state RegistrationState @default(PENDING)
  paymentId             String?  @unique
  subscriptionId        String?  @unique
  expiresAt             DateTime
  handoffTokenHash      String?  @unique
  handoffTokenExpiresAt DateTime?
  handoffTokenUsedAt    DateTime?
  tenantData            Json
  tenantSiteData        Json
  userData              Json
  identityData          Json
  profileData           Json
  provisionedUserId       String?
  provisionedTenantId     String?
  provisionedMembershipId String?
  provisionedProfileId    String?
  provisionedIdentityId   String?
  provisionedTenantSiteId  String?
  paymentStatus         String?
  paymentStatusDetail   String?
  webhookProcessedAt    DateTime?
  approvedAt            DateTime?
  provisionedAt         DateTime?
  rejectedAt            DateTime?
  expiredAt             DateTime?
  createdAt             DateTime @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @db.Timestamptz(3)

  @@index([state])
  @@index([expiresAt])
  @@index([handoffTokenExpiresAt])
  @@index([subscriptionId])
}

// ============== TENANT SITE ==============

model TenantSite {
  id             String         @id @unique @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  systemState    SystemState    @default(ACTIVE)
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  name           String
  legalName      String
  externalId     String?
  taxId          String         @unique
  siteType       TenantSiteType
  isHeadquarters Boolean        @default(false)

  @@unique([tenantId, taxId])
}

// ============== BILLING ==============

model Plan {
  id                  String   @id @default(uuid())
  type                String   @unique
  name                String
  description         String?
  basePrice           Int
  currency            String   @default("BRL")
  includedUsers       Int
  additionalUserPrice Int?
  maxProducts         Int?
  maxRevisions        Int?

  features            Json
  isPublic            Boolean  @default(true)
  isActive            Boolean  @default(true)
  // Phase 5: Added for validation logic (allowsAdditionalUsers check in subscription service).
  // This field deviates from EPIC_007 schema which did not originally include it.
  allowsAdditionalUsers Boolean @default(false)

  createdAt           DateTime @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @db.Timestamptz(3)

  @@index([type])
  @@index([isPublic])
  @@index([isActive])
}

model Subscription {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])

  planType               String
  status                 String
  currency               String   @default("BRL")

  provider               String   @default("mercadopago")
  providerSubscriptionId String   @unique
  providerPreapprovalId  String?  @unique
  providerCustomerId     String?

  basePriceSnapshot      Int
  additionalUserPriceSnapshot Int?
  includedUsersSnapshot   Int

  additionalUsers        Int      @default(0)
  currentAmount          Int
  nextBillingAmount      Int?

  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  graceEndsAt            DateTime?
  cancelAtPeriodEnd      Boolean  @default(false)
  pendingPlanType        String?
  pendingEffectiveFrom   DateTime?
  pendingNewAmount       Int?

  failedPaymentCount     Int      @default(0)
  lastPaymentAt          DateTime?
  lastWebhookAt          DateTime?

  createdAt              DateTime @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime @updatedAt @db.Timestamptz(3)

  events                 SubscriptionEvent[]

  @@index([status])
  @@index([planType])
  @@index([currentPeriodEnd])
  @@index([graceEndsAt])
}

model SubscriptionEvent {
  id                   String       @id @default(uuid())
  subscriptionId       String
  subscription         Subscription @relation(fields: [subscriptionId], references: [id])

  providerEventId      String?      @unique
  providerEventType    String
  actionStatus         ActionStatus @default(COMPLETED)
  statusBefore         String?
  statusAfter          String?
  payload              Json

  createdAt            DateTime     @default(now()) @db.Timestamptz(3)

  @@index([subscriptionId])
  @@index([providerEventType])
  @@index([createdAt])
}

// ============== PRODUCTS DOMAIN ==============

model Product {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(3)
  systemState   SystemState   @default(ACTIVE)
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  name          String
  code          String
  status        ProductStatus @default(DRAFT)

  commercialName    String?
  denomination      String?
  productType       String?
  notes             String?
  barcodeGtin       String?
  declaredWeight    Decimal?
  declaredVolume    Decimal?
  shelfLifeDays     Int?
  storageConditions String?

  nutritionInfo       ProductNutritionalInfo?
  labelProfile        LabelProfile?
  formulationVersions FormulationVersion[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProductNutritionalInfo {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id])
  servingSize Decimal?
  data        Json?
}

model LabelProfile {
  id            String             @id @default(uuid())
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(3)
  productId     String             @unique
  product       Product            @relation(fields: [productId], references: [id])
  status        LabelProfileStatus @default(DRAFT)
  designerData  Json?
  gerencialData Json?
  approvedAt    DateTime?
}

// ============== FORMULATIONS DOMAIN ==============

model FormulationVersion {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3)
  systemState SystemState @default(ACTIVE)
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  version     Int
  notes       String?

  revisions FormulationRevision[]

  @@unique([productId, version])
  @@index([tenantId])
  @@index([productId])
}

model FormulationRevision {
  id                     String               @id @default(uuid())
  createdAt              DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime             @updatedAt @db.Timestamptz(3)
  systemState            SystemState          @default(ACTIVE)
  formulationVersionId   String
  formulationVersion     FormulationVersion   @relation(fields: [formulationVersionId], references: [id])
  revision               Int
  notes                  String?
  nutritionalSummary     Json?
  complianceSummary      Json?

  items FormulationItem[]

  @@unique([formulationVersionId, revision])
  @@index([formulationVersionId])
}

model FormulationItem {
  id                    String               @id @default(uuid())
  createdAt             DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime             @updatedAt @db.Timestamptz(3)
  formulationRevisionId String
  formulationRevision   FormulationRevision  @relation(fields: [formulationRevisionId], references: [id])
  ingredientId          String
  ingredient            Ingredient           @relation(fields: [ingredientId], references: [id])
  quantity              Decimal
  unit                  String               @default("g")

  @@index([formulationRevisionId])
  @@index([ingredientId])
}

// ============== BASE CATALOGS (Platform-Scoped) ==============

model BaseAllergen {
  id            String      @id @unique @default(uuid())
  createdAt     DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  name          String      @unique
  category      String?
  regulatoryRef String?
  sortOrder     Int         @default(0)

  ingredientBaseAllergens IngredientBaseAllergen[]
}

model BaseNutrient {
  id            String          @id @unique @default(uuid())
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(3)
  systemState   SystemState     @default(ACTIVE)
  name          String          @unique
  unit          NutrientUnit
  category      NutrientCategory
  sortOrder     Int             @default(0)

  ingredientNutrients IngredientBaseNutrient[]
}

// ============== INGREDIENT DOMAIN ==============

model TenantAllergen {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  category      String?
  regulatoryRef String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  ingredients   IngredientTenantAllergen[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TenantNutrient {
  id            String          @id @unique @default(uuid())
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(3)
  systemState   SystemState     @default(ACTIVE)
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  name          String
  unit          NutrientUnit
  category      NutrientCategory
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)

  ingredients   IngredientTenantNutrient[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model FunctionalGroup {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  code          String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  ingredients   Ingredient[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Company {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  type          String
  contactInfo   String?
  taxId         String?

  manufacturedIngredients Ingredient[] @relation("ManufacturerIngredients")
  suppliedIngredients     Ingredient[] @relation("SupplierIngredients")

  @@unique([tenantId, taxId])
  @@index([tenantId])
}

model TechnicalInfoSource {
  id            String                  @id @unique @default(uuid())
  createdAt     DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime                @updatedAt @db.Timestamptz(3)
  systemState   SystemState             @default(ACTIVE)
  tenantId      String
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  sourceType    TechnicalInfoSourceType
  referenceName String
  url           String?
  documentRef   String?

  ingredients   Ingredient[]

  @@index([tenantId])
}

model Ingredient {
  id                String                   @id @unique @default(uuid())
  createdAt         DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime                 @updatedAt @db.Timestamptz(3)
  systemState       SystemState              @default(ACTIVE)
  tenantId          String
  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  code              String
  internalName      String
  commercialName    String?
  saleDenomination   String?
  functionalGroupId String?
  functionalGroup   FunctionalGroup?         @relation(fields: [functionalGroupId], references: [id])
  ingredientFunction IngredientFunctionType
  notes             String?
  manufacturerId    String?
  manufacturer      Company?                 @relation("ManufacturerIngredients", fields: [manufacturerId], references: [id])
  supplierId        String?
  supplier          Company?                 @relation("SupplierIngredients", fields: [supplierId], references: [id])
  technicalSourceId String?
  technicalSource   TechnicalInfoSource?     @relation(fields: [technicalSourceId], references: [id])
  usageIndication   String?
  ingredientsListDesc String?

  tenantAllergens   IngredientTenantAllergen[]
  tenantNutrients   IngredientTenantNutrient[]
  baseAllergens     IngredientBaseAllergen[]
  baseNutrients     IngredientBaseNutrient[]
  regulatoryProfile IngredientRegulatoryProfile?
  labelingProfile   IngredientLabelingProfile?
  technicalProfile  IngredientTechnicalProfile?
  formulationItems  FormulationItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([functionalGroupId])
  @@index([manufacturerId])
  @@index([supplierId])
  @@index([technicalSourceId])
}

model IngredientTenantAllergen {
  id            String               @id @unique @default(uuid())
  createdAt     DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime             @updatedAt @db.Timestamptz(3)
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  ingredientId  String
  ingredient    Ingredient           @relation(fields: [ingredientId], references: [id])
  allergenId    String
  allergen      TenantAllergen       @relation(fields: [allergenId], references: [id])
  relationType  AllergenRelationType

  @@unique([tenantId, ingredientId, allergenId, relationType])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([allergenId])
}

model IngredientTenantNutrient {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  ingredientId  String
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
  nutrientId    String
  nutrient      TenantNutrient @relation(fields: [nutrientId], references: [id])
  value         Decimal?

  @@unique([tenantId, ingredientId, nutrientId])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([nutrientId])
}

model IngredientBaseAllergen {
  id            String               @id @unique @default(uuid())
  createdAt     DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime             @updatedAt @db.Timestamptz(3)
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  ingredientId  String
  ingredient    Ingredient           @relation(fields: [ingredientId], references: [id])
  baseAllergenId String
  baseAllergen  BaseAllergen         @relation(fields: [baseAllergenId], references: [id])
  relationType  AllergenRelationType

  @@unique([tenantId, ingredientId, baseAllergenId])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([baseAllergenId])
}

model IngredientBaseNutrient {
  id             String   @id @unique @default(uuid())
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  ingredientId   String
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id])
  baseNutrientId String
  baseNutrient   BaseNutrient @relation(fields: [baseNutrientId], references: [id])
  value          Decimal?

  @@unique([tenantId, ingredientId, baseNutrientId])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([baseNutrientId])
}

