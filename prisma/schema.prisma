// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  module   = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============== ENUMS ==============

enum SystemState {
  ACTIVE
  LOCKED
  DELETED
}

enum UserScope {
  PLATFORM
  TENANT
}

enum PlatformRole {
  ADMIN
  USER
}

enum TenantRole {
  ADMIN
  USER
}

enum AuthProviderType {
  EMAIL
  CPF
}

// ============== POLYMORPHIC ENUMS ==============

enum OwnerType {
  MemberProfile
  TenantSite
}

enum AddressType {
  HOME
  WORK
  BILLING
  SHIPPING
}

enum PhoneType {
  MOBILE
  HOME
  WORK
  WHATSAPP
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  CPF
  CNPJ
  RG
  PASSPORT
}

enum TenantSiteType {
  FACTORY
  WAREHOUSE
  OFFICE
}

enum RegistrationState {
  PENDING
  APPROVED
  PROVISIONING
  PROVISIONED
  REJECTED
  EXPIRED
}

enum IngredientFunctionType {
  ADDITIVE
  INGREDIENT
}

enum FlavorOriginType {
  NOT_APPLICABLE
  NATURAL
  IDENTICAL_TO_NATURAL
  ARTIFICIAL
  NO_FLAVOR
}

enum ColorantOriginType {
  NOT_APPLICABLE
  NATURAL
  IDENTICAL_TO_NATURAL
  SYNTHETIC
  NO_COLORANT
}

enum NutrientUnit {
  G
  MG
  MCG
  KCAL
}

enum NutrientCategory {
  MANDATORY_DECLARATION
  SPECIFIC_CARBS
  FATTY_ACIDS
  MINERALS
  FIBER
  VITAMINS
  OTHER
}

enum FormulationRevisionStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  HISTORIC
}

enum ProductPanelType {
  MAIN
  SECONDARY
}

enum MeasurementType {
  MASS
  VOLUME
  LENGTH
  TIME
  TEMPERATURE
  UNITY
  RATIO
  ENERGY
}

enum MeasurementSystem {
  METRIC
  IMPERIAL
  US_CUSTOMARY
}

enum DeclarationFlagScope {
  INGREDIENT
  FORMULATION
  BOTH
}

enum AllergenRelationType {
  CONTAINS
  MAY_CONTAIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PlanType {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  GRACE
  PAUSED
  CANCELED
  EXPIRED
}

enum ActionStatus {
  COMPLETED
  SCHEDULED
  CANCELED
  FAILED
}

// ============== TENANT ==============

model Tenant {
  id                 String      @id @unique @default(uuid())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  systemState        SystemState @default(ACTIVE)
  name               String
  slug               String?
  website            String?     @unique
  locale             String
  timezone           String
  language           String
  logoUrl            String?
  settings           Json?
  providerCustomerId String?

  memberships  TenantMembership[]
  sessions     Session[]
  sites        TenantSite[]
  auditLogs    AuditLog[]
  subscription Subscription?

  // Products domain
  products_TE                Product_TE[]
  productFamilies_TE         ProductFamily_TE[]
  commercialLines_TE         CommercialLine_TE[]
  claims_TE                  Claim_TE[]
  formulationVersions_TE     FormulationVersion_TE[]
  productLabelFields_TE      ProductLabelField_TE[]
  productPanels_TE           ProductPanel_TE[]
  productNutrientOverrides_TE ProductNutrientOverride_TE[]
  productClaims_TE           ProductClaim_TE[]

  // Ingredient domain - tenant catalogs
  technicalSourceTypes_TE    TechnicalSourceType_TE[]

  // Ingredient domain
  functionalGroups_TE        FunctionalGroup_TE[]
  companies_TE               Company_TE[]
  technicalSources_TE        TechnicalSource_TE[]
  ingredients_TE             Ingredient_TE[]
  ingredientAllergens_TE     IngredientAllergen_TE[]
  ingredientNutrients_TE     IngredientNutrient_TE[]
  ingredientFlags_TE         IngredientFlag_TE[]
  ingredientCosts_TE         IngredientCost_TE[]

  // Formulation domain
  formulationRevisions_TE           FormulationRevision_TE[]
  formulationRegulatoryDeclarations_TE FormulationRegulatoryDeclaration_TE[]
  formulationAllergens_TE           FormulationAllergen_TE[]
  formulationNutritions_TE          FormulationNutrition_TE[]
  formulationOgmDonors_TE           FormulationOgmDonor_TE[]
}

// ============== USER ==============

model User {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  scope       UserScope   @default(TENANT)

  // Relations
  platformMembership PlatformMembership?
  tenantMemberships  TenantMembership[]
  identities         Identity[]
  sessions           Session[]
  auditLogs          AuditLog[]
}

// ============== MEMBERSHIP ==============

model PlatformMembership {
  id            String         @id @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  roles         PlatformRole[] @default([USER])
  memberProfile MemberProfile?
}

model TenantMembership {
  id            String         @id @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  isOwner       Boolean        @default(false)
  roles         TenantRole[]   @default([USER])
  memberProfile MemberProfile?

  @@unique([userId, tenantId])
}

// ============== SESSION ==============

model Session {
  id               String    @id @unique @default(uuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  refreshTokenHash String    @unique
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenHash])
}

// ============== IDENTITY ==============

model Identity {
  id               String           @id @default(uuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  systemState      SystemState      @default(ACTIVE)
  authProviderType AuthProviderType
  identifier       String
  secretHash       String?
  user             User             @relation(fields: [userId], references: [id])
  userId           String

  @@unique([authProviderType, identifier])
  @@index([identifier])
}

// ============== POLYMORPHIC ADDRESS ==============

model Address {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)

  // Polymorphic owner reference
  ownerId   String
  ownerType OwnerType
  tenantId  String     @default("MIGRATION_PLACEHOLDER") // TODO(EP-002/Wave3): Remove @default after all code paths set tenantId explicitly

  // Address fields
  type       AddressType
  streetType String?
  street     String
  number     String
  complement String?
  district   String?
  city       String
  state      String
  postalCode String
  country    String      @default("BR")
  isDefault  Boolean     @default(false)

  // Constraints
  @@unique([ownerId, ownerType, type])
  @@index([ownerId, ownerType])
  @@index([tenantId])
}

// ============== POLYMORPHIC PHONE ==============

model Phone {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)

  // Polymorphic owner reference
  ownerId   String
  ownerType OwnerType
  tenantId  String     @default("MIGRATION_PLACEHOLDER") // TODO(EP-002/Wave3): Remove @default after all code paths set tenantId explicitly

  // Phone fields
  type        PhoneType
  countryCode String    @default("55")
  number      String
  extension   String?
  isWhatsapp  Boolean   @default(false)
  isDefault   Boolean   @default(false)

  // Constraints
  @@unique([ownerId, ownerType, type])
  @@index([ownerId, ownerType])
  @@index([tenantId])
}

// ============== MEMBER PROFILE ==============

model MemberProfile {
  id                   String              @id @unique @default(uuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  systemState          SystemState         @default(ACTIVE)
  externalId           String?
  fullName             String
  displayName          String?
  dateOfBirth          DateTime?
  gender               Gender?
  photoUrl             String?
  locale               String
  timezone             String
  language             String
  platformMembershipId String?             @unique
  platformMembership   PlatformMembership? @relation(fields: [platformMembershipId], references: [id])
  tenantMembershipId   String?             @unique
  tenantMembership     TenantMembership?   @relation(fields: [tenantMembershipId], references: [id])

  documents MemberProfileDocument[]
}

// ============== MEMBER PROFILE DOCUMENT ==============

model MemberProfileDocument {
  id              String        @id @unique @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  systemState     SystemState   @default(ACTIVE)
  memberProfileId String
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id])
  type            DocumentType
  value           String
  normalizedValue String

  @@unique([memberProfileId, type])
}

// ============== AUDIT LOG ==============

model AuditLog {
  id                    String   @id @unique @default(uuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id])
  tenantId              String?
  tenant                Tenant?  @relation(fields: [tenantId], references: [id])
  entityName            String
  entityId              String
  ipAddress             String?
  userAgent             String?
  action                String
  before                Json?
  after                 Json?
  description           String?
  tenantImpersonationId String?  @map("tenant_impersonation_id")

  @@index([tenantId])
  @@index([userId])
  @@index([entityName])
  @@index([entityId])
  @@index([createdAt])
}

// ============== TENANT REGISTRATION ==============

model TenantRegistration {
  id                      String            @id @default(uuid())
  externalRef             String            @unique
  // Valid values defined in RegistrationState enum (backend/src/shared/enums.ts)
  state                   RegistrationState @default(PENDING)
  paymentId               String?           @unique
  subscriptionId          String?           @unique
  providerCustomerId      String?
  expiresAt               DateTime
  handoffTokenHash        String?           @unique
  handoffTokenExpiresAt   DateTime?
  handoffTokenUsedAt      DateTime?
  tenantData              Json
  tenantSiteData          Json
  userData                Json
  identityData            Json
  profileData             Json
  addressData             Json?
  phoneData               Json?
  provisionedUserId       String?
  provisionedTenantId     String?
  provisionedMembershipId String?
  provisionedProfileId    String?
  provisionedIdentityId   String?
  provisionedTenantSiteId String?
  provisionedAddressId    String?
  provisionedPhoneId      String?
  paymentStatus           String?
  paymentStatusDetail     String?
  webhookProcessedAt      DateTime?
  approvedAt              DateTime?
  provisionedAt           DateTime?
  rejectedAt              DateTime?
  expiredAt               DateTime?
  createdAt               DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime          @updatedAt @db.Timestamptz(3)

  @@index([state])
  @@index([expiresAt])
  @@index([handoffTokenExpiresAt])
  @@index([subscriptionId])
}

// ============== TENANT SITE ==============

model TenantSite {
  id             String         @id @unique @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  systemState    SystemState    @default(ACTIVE)
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  name           String
  legalName      String
  externalId     String?
  taxId          String         @unique
  siteType       TenantSiteType
  isHeadquarters Boolean        @default(false)

  @@unique([tenantId, taxId])
}

// ============== BILLING ==============

model Plan {
  id                  String  @id @default(uuid())
  type                String  @unique
  name                String
  description         String?
  basePrice           Int
  currency            String  @default("BRL")
  includedUsers       Int
  additionalUserPrice Int?
  maxProducts         Int?
  maxRevisions        Int?

  features              Json
  isPublic              Boolean @default(true)
  isActive              Boolean @default(true)
  // Phase 5: Added for validation logic (allowsAdditionalUsers check in subscription service).
  // This field deviates from EPIC_007 schema which did not originally include it.
  allowsAdditionalUsers Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([type])
  @@index([isPublic])
  @@index([isActive])
}

model Subscription {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  planType String
  status   String
  currency String @default("BRL")

  provider               String  @default("free")
  providerSubscriptionId String  @unique
  providerCustomerId     String?

  basePriceSnapshot           Int
  additionalUserPriceSnapshot Int?
  includedUsersSnapshot       Int

  additionalUsers   Int  @default(0)
  currentAmount     Int
  nextBillingAmount Int?

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  graceEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  pendingPlanType      String?
  pendingEffectiveFrom DateTime?
  pendingNewAmount     Int?

  failedPaymentCount Int       @default(0)
  lastPaymentAt      DateTime?
  lastWebhookAt      DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  events SubscriptionEvent[]

  @@index([status])
  @@index([planType])
  @@index([currentPeriodEnd])
  @@index([graceEndsAt])
}

model SubscriptionEvent {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  providerEventId   String?      @unique
  providerEventType String
  actionStatus      ActionStatus @default(COMPLETED)
  statusBefore      String?
  statusAfter       String?
  payload           Json

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([subscriptionId])
  @@index([providerEventType])
  @@index([createdAt])
}

// ============== PRODUCTS DOMAIN ==============

model Product_TE {
  id                String        @id @default(uuid())
  createdAt         DateTime      @default(now()) @db.Timestamptz(3)
  createdBy         String?
  updatedAt         DateTime      @updatedAt @db.Timestamptz(3)
  updatedBy         String?
  systemState       SystemState   @default(ACTIVE)
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id])

  // Identity
  internalName      String
  code              String
  externalCode      String?
  displayName       String?
  status            ProductStatus @default(DRAFT)

  // Commercial
  commercialName    String?
  saleDenomination  String?
  productType       String?
  barcodeGtin       String?
  notes             String?

  // Packaging
  packagingType     String?
  batchCode         String?
  shelfLifeDays     Int?
  storageConditions String?
  declaredWeight    Decimal? @db.Decimal(12,6)
  declaredVolume    Decimal? @db.Decimal(12,6)

  // Classifications
  productFamilyId   String?
  commercialLineId  String?

  // Relations
  productFamily            ProductFamily_TE?             @relation(fields: [productFamilyId], references: [id])
  commercialLine           CommercialLine_TE?            @relation(fields: [commercialLineId], references: [id])
  formulationVersions_TE   FormulationVersion_TE[]
  productLabelFields_TE    ProductLabelField_TE[]
  productPanels_TE         ProductPanel_TE[]
  productNutrientOverrides_TE ProductNutrientOverride_TE[]
  productClaims_TE         ProductClaim_TE[]

  @@map("Product")
  @@unique([tenantId, code])
  @@unique([tenantId, internalName])
  @@index([tenantId, externalCode])
  @@index([tenantId])
}

// ============== PRODUCT CHILD MODELS ==============

model ProductLabelField_TE {
  id              String      @id @default(uuid())
  createdAt       DateTime    @default(now()) @db.Timestamptz(3)
  createdBy       String?
  updatedAt       DateTime    @updatedAt @db.Timestamptz(3)
  updatedBy       String?
  systemState     SystemState @default(ACTIVE)
  tenantId        String
  productId       String
  labelFieldId    String
  labelField      LabelField_PL @relation(fields: [labelFieldId], references: [id])
  designerValue   String?
  gerencialValue  String?

  product     Product_TE  @relation(fields: [productId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id])

  // Nota: tenantId não incluso no unique — UUIDs são globalmente únicos
  @@unique([productId, labelFieldId])
  @@index([tenantId])
  @@index([labelFieldId])
}

model ProductPanel_TE {
  id                    String            @id @default(uuid())
  createdAt             DateTime          @default(now()) @db.Timestamptz(3)
  createdBy             String?
  updatedAt             DateTime          @updatedAt @db.Timestamptz(3)
  updatedBy             String?
  systemState           SystemState       @default(ACTIVE)
  tenantId              String
  tenant                Tenant      @relation(fields: [tenantId], references: [id])
  productId             String
  panelNumber           Int
  type                  ProductPanelType
  geometricFormatTypeId String?
  geometricFormatType   PanelGeometricFormatType_PL? @relation(fields: [geometricFormatTypeId], references: [id])
  geometricFormatValues Json?

  product     Product_TE  @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([productId])
}

model ProductNutrientOverride_TE {
  id                String   @id @default(uuid())
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  createdBy         String?
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)
  updatedBy         String?
  systemState       SystemState @default(ACTIVE)
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  productId         String
  nutrientId        String
  overrideNutrient  Nutrient_PL @relation(fields: [nutrientId], references: [id])
  overriddenValue   Decimal @db.Decimal(12,6)
  notes             String?

  product     Product_TE @relation(fields: [productId], references: [id])

  // Nota: tenantId não incluso no unique — UUIDs são globalmente únicos
  @@unique([productId, nutrientId])
  @@index([tenantId])
  @@index([nutrientId])
}

model ProductClaim_TE {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)
  createdBy   String?
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3)
  updatedBy   String?
  systemState SystemState @default(ACTIVE)
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  productId   String
  claimId     String
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)

  product     Product_TE  @relation(fields: [productId], references: [id])
  claim       Claim_TE    @relation(fields: [claimId], references: [id])

  // Nota: tenantId não incluso no unique — UUIDs são globalmente únicos
  @@unique([productId, claimId])
  @@index([tenantId])
  @@index([claimId])
}

// ============== FORMULATIONS DOMAIN ==============

model FormulationVersion_TE {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)
  createdBy   String?
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3)
  updatedBy   String?
  systemState SystemState @default(ACTIVE)
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product_TE  @relation(fields: [productId], references: [id])
  version     Int
  notes       String?

  revisions_TE FormulationRevision_TE[]

  @@map("FormulationVersion")
  @@unique([productId, version])
  @@index([tenantId])
  @@index([productId])
}

model FormulationRevision_TE {
  id                    String                   @id @default(uuid())
  createdAt             DateTime                 @default(now()) @db.Timestamptz(3)
  createdBy             String?
  updatedAt             DateTime                 @updatedAt @db.Timestamptz(3)
  updatedBy             String?
  systemState           SystemState              @default(ACTIVE)
  tenantId              String
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  formulationVersionId  String
  formulationVersion_TE FormulationVersion_TE    @relation(fields: [formulationVersionId], references: [id])
  revision              Int
  status                FormulationRevisionStatus @default(DRAFT)
  approverId            String?
  approvedBy            String?
  approvedAt            DateTime?
  drift                 Boolean @default(false)
  notes                 String?

  items_TE                    FormulationItem_TE[]
  regulatoryDeclarations_TE   FormulationRegulatoryDeclaration_TE[]
  allergen_TE                 FormulationAllergen_TE?
  nutritionValues_TE          FormulationNutrition_TE[]
  ogmDonors_TE                FormulationOgmDonor_TE[]

  @@map("FormulationRevision")
  @@unique([formulationVersionId, revision])
  @@index([tenantId])
  @@index([formulationVersionId])
}

model FormulationItem_TE {
  id                    String                  @id @default(uuid())
  createdAt             DateTime                @default(now()) @db.Timestamptz(3)
  createdBy             String?
  updatedAt             DateTime                @updatedAt @db.Timestamptz(3)
  updatedBy             String?
  formulationRevisionId String
  formulationRevision_TE FormulationRevision_TE @relation(fields: [formulationRevisionId], references: [id])
  ingredientId          String
  ingredient_TE         Ingredient_TE           @relation(fields: [ingredientId], references: [id])
  quantity              Decimal @db.Decimal(12,6)
  unitId                String
  unitOfMeasure         UnitOfMeasure_PL        @relation(fields: [unitId], references: [id])
  tenantId              String
  usageCategory         String?
  componentGroup        String?
  sortOrder             Int                     @default(0)
  notes                 String?

  @@map("FormulationItem")
  @@index([tenantId])
  @@index([formulationRevisionId])
  @@index([ingredientId])
}

// ============== FORMULATION CHILD MODELS ==============

model FormulationRegulatoryDeclaration_TE {
  id                    String      @id @default(uuid())
  createdAt             DateTime    @default(now()) @db.Timestamptz(3)
  createdBy             String?
  updatedAt             DateTime    @updatedAt @db.Timestamptz(3)
  updatedBy             String?
  systemState           SystemState @default(ACTIVE)
  tenantId              String
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  formulationRevisionId String
  formulationRevision_TE FormulationRevision_TE @relation(fields: [formulationRevisionId], references: [id])
  flagId                String
  flagDeclaration       DeclarationFlag_PL     @relation(fields: [flagId], references: [id])
  flagValue             Boolean     @default(true)
  notes                 String?

  @@unique([formulationRevisionId, flagId])
  @@index([tenantId])
  @@index([formulationRevisionId])
}

model FormulationAllergen_TE {
  id                    String      @id @default(uuid())
  createdAt             DateTime    @default(now()) @db.Timestamptz(3)
  createdBy             String?
  updatedAt             DateTime    @updatedAt @db.Timestamptz(3)
  updatedBy             String?
  systemState           SystemState @default(ACTIVE)
  tenantId              String
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  formulationRevisionId String      @unique
  formulationRevision_TE FormulationRevision_TE @relation(fields: [formulationRevisionId], references: [id])
  allergenDeclaration   String?
  allergenMayContain    String?

  @@index([tenantId])
}

model FormulationNutrition_TE {
  id                    String          @id @default(uuid())
  createdAt             DateTime        @default(now()) @db.Timestamptz(3)
  createdBy             String?
  updatedAt             DateTime        @updatedAt @db.Timestamptz(3)
  updatedBy             String?
  systemState           SystemState     @default(ACTIVE)
  tenantId              String
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  formulationRevisionId String
  formulationRevision_TE FormulationRevision_TE @relation(fields: [formulationRevisionId], references: [id])
  nutrientId            String
  nutrient              Nutrient_PL            @relation(fields: [nutrientId], references: [id])
  declaredValue         Decimal? @db.Decimal(12,6)
