model Ingredient_TE {
  id                  String                 @id @unique @default(uuid())
  createdAt           DateTime               @default(now()) @db.Timestamptz(3)
  createdBy           String?
  updatedAt           DateTime               @updatedAt @db.Timestamptz(3)
  updatedBy           String?
  systemState         SystemState            @default(ACTIVE)
  tenantId            String
  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  code                String
  internalName        String
  externalCode        String?
  commercialName      String?
  saleDenomination    String?
  ingredientFunction  IngredientFunctionType
  notes               String?
  usageIndication     String?
  ingredientsListDesc String?

  // Manufacturer / Supplier / Tech Source
  functionalGroupId   String?
  functionalGroup     FunctionalGroup_TE?    @relation(fields: [functionalGroupId], references: [id])
  manufacturerId      String?
  manufacturer        Company_TE?            @relation("ManufacturerIngredients", fields: [manufacturerId], references: [id])
  supplierId          String?
  supplier            Company_TE?            @relation("SupplierIngredients", fields: [supplierId], references: [id])
  technicalSourceId   String?
  technicalSource     TechnicalSource_TE?    @relation(fields: [technicalSourceId], references: [id])

  // === Regulatory Profile (merged) ===
  hasRtiqPiq              Boolean             @default(false)
  gmoIngredient           String?
  gmoDonorSpecies         String?
  gmoPercentage           Decimal? @db.Decimal(12,6)
  irradiatedIngredient    String?
  flavorOriginType        FlavorOriginType?
  colorantOriginType      ColorantOriginType?

  // === Labeling Profile (merged) ===
  containsAddedSugars                        Boolean @default(false)
  containsIngredientWithAddedSugars          Boolean @default(false)
  containsNaturallyOccurringSugarSubstitutes Boolean @default(false)
  usesProcessingThatIncreasesSugars          Boolean @default(false)
  containsAddedFatsOrOils                    Boolean @default(false)
  containsButterOrMargarine                  Boolean @default(false)
  containsDairyCream                         Boolean @default(false)
  containsIngredientsWithFatsOrCream         Boolean @default(false)

  // === Technical Profile (merged) ===
  pac         Decimal? @db.Decimal(12,6)
  pod         Decimal? @db.Decimal(12,6)
  totalSolids Decimal? @db.Decimal(12,6)
  ashContent  Decimal? @db.Decimal(12,6)

  // Relations to child tables
  allergenJunctions_TE  IngredientAllergen_TE[]
  nutrientJunctions_TE  IngredientNutrient_TE[]
  flagJunctions_TE      IngredientFlag_TE[]
  costRecords_TE        IngredientCost_TE[]
  formulationItems_TE   FormulationItem_TE[]

  @@map("Ingredient")
  @@unique([tenantId, code])
  @@unique([tenantId, internalName])
  @@index([tenantId, externalCode])
  @@index([tenantId])
  @@index([functionalGroupId])
  @@index([manufacturerId])
  @@index([supplierId])
  @@index([technicalSourceId])
}

model IngredientAllergen_TE {
  id            String               @id @unique @default(uuid())
  createdAt     DateTime             @default(now()) @db.Timestamptz(3)
  createdBy     String?
  updatedAt     DateTime             @updatedAt @db.Timestamptz(3)
  updatedBy     String?
  tenantId      String
