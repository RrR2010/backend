// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  module   = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SystemState {
  ACTIVE
  LOCKED
  HIDDEN
}

model Tenant {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  name        String

  memberships Membership[]
}

enum PlatformRole {
  ADMIN
  MEMBER
}

model User {
  id           String         @id @default(uuid())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  systemState  SystemState    @default(ACTIVE)
  platformRoles PlatformRole[] @default([MEMBER])
  name         String
  email        String         @unique
  passwordHash String
  code         String?        @unique

  memberships Membership[]
}

enum TenantRole {
  ADMIN
  USER
}

model Membership {
  id          String       @id @unique @default(uuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  systemState SystemState  @default(ACTIVE)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  roles       TenantRole[] @default([USER])
}
