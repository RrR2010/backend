// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  module   = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============== ENUMS ==============

enum SystemState {
  ACTIVE
  LOCKED
  HIDDEN
}

enum UserScope {
  PLATFORM
  TENANT
}

enum PlatformRole {
  ADMIN
  USER
}

enum TenantRole {
  ADMIN
  USER
}

enum AuthProviderType {
  EMAIL
  CPF
}

// ============== POLYMORPHIC ENUMS ==============

enum OwnerType {
  MemberProfile
  TenantSite
}

enum AddressType {
  HOME
  WORK
  BILLING
  SHIPPING
}

enum PhoneType {
  MOBILE
  HOME
  WORK
  WHATSAPP
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  CPF
  CNPJ
  RG
  PASSPORT
}

enum TenantSiteType {
  FACTORY
  WAREHOUSE
  OFFICE
}

enum RegistrationState {
  PENDING
  APPROVED
  PROVISIONING
  PROVISIONED
  REJECTED
  EXPIRED
}

enum IngredientFunctionType {
  ADDITIVE
  INGREDIENT
}

enum TechnicalInfoSourceType {
  DATASHEET
  IBGE
  LAB_REPORT
  INTERNET
  REGULATORY_TABLE
}

enum FlavorOriginType {
  NOT_APPLICABLE
  NATURAL
  IDENTICAL_TO_NATURAL
  ARTIFICIAL
  NO_FLAVOR
}

enum ColorantOriginType {
  NOT_APPLICABLE
  NATURAL
  IDENTICAL_TO_NATURAL
  SYNTHETIC
  NO_COLORANT
}

enum NutrientUnit {
  G
  MG
  MCG
  KCAL
}

enum NutrientCategory {
  MACRONUTRIENT
  SUGAR
  FATTY_ACID
  VITAMIN
  MINERAL
  AMINO_ACID
  POLYOL
  FIBER
  BIOACTIVE
  OTHER
}

enum AllergenRelationType {
  CONTAINS
  MAY_CONTAIN
}

enum PlanType {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE
  PAUSED
  CANCELED
  EXPIRED
}

// ============== TENANT ==============

model Tenant {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  name        String
  slug        String?
  website     String?     @unique
  locale      String
  timezone    String
  language    String
  logoUrl     String?
  settings    Json?

  memberships TenantMembership[]
  sessions    Session[]
  sites       TenantSite[]
  auditLogs   AuditLog[]
  subscription Subscription?

  // Ingredient domain
  allergens           Allergen[]
  nutrients           Nutrient[]
  functionalGroups    FunctionalGroup[]
  companies           Company[]
  technicalInfoSources TechnicalInfoSource[]
  ingredients         Ingredient[]
  ingredientAllergens IngredientAllergen[]
  ingredientNutrients IngredientNutrient[]
  ingredientRegulatoryProfiles IngredientRegulatoryProfile[]
  ingredientLabelingProfiles   IngredientLabelingProfile[]
  ingredientTechnicalProfiles  IngredientTechnicalProfile[]
}

// ============== USER ==============

model User {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  scope       UserScope   @default(TENANT)

  // Relations
  platformMembership PlatformMembership?
  tenantMemberships  TenantMembership[]
  identities         Identity[]
  sessions           Session[]
  auditLogs          AuditLog[]
}

// ============== MEMBERSHIP ==============

model PlatformMembership {
  id            String         @id @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  roles         PlatformRole[] @default([USER])
  memberProfile MemberProfile?
}

model TenantMembership {
  id            String         @id @unique @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  isOwner       Boolean        @default(false)
  roles         TenantRole[]   @default([USER])
  memberProfile MemberProfile?

  @@unique([userId, tenantId])
}

// ============== SESSION ==============

model Session {
  id               String    @id @unique @default(uuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  refreshTokenHash String    @unique
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenHash])
}

// ============== IDENTITY ==============

model Identity {
  id               String           @id @default(uuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  systemState      SystemState      @default(ACTIVE)
  authProviderType AuthProviderType
  identifier       String
  secretHash       String?
  user             User             @relation(fields: [userId], references: [id])
  userId           String

  @@unique([authProviderType, identifier])
  @@index([identifier])
}

// ============== POLYMORPHIC ADDRESS ==============

model Address {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)

  // Polymorphic owner reference
  ownerId   String
  ownerType OwnerType

  // Address fields
  type       AddressType
  street     String
  number     String
  complement String?
  district   String?
  city       String
  state      String
  postalCode String
  country    String      @default("BR")
  isDefault  Boolean     @default(false)

  // Constraints
  @@unique([ownerId, ownerType, type])
  @@index([ownerId, ownerType])
}

// ============== POLYMORPHIC PHONE ==============

model Phone {
  id          String      @id @unique @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)

  // Polymorphic owner reference
  ownerId   String
  ownerType OwnerType

  // Phone fields
  type        PhoneType
  countryCode String    @default("55")
  number      String
  isWhatsapp  Boolean   @default(false)
  isDefault   Boolean   @default(false)

  // Constraints
  @@unique([ownerId, ownerType, type])
  @@index([ownerId, ownerType])
}

// ============== MEMBER PROFILE ==============

model MemberProfile {
  id                   String              @id @unique @default(uuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  systemState          SystemState         @default(ACTIVE)
  externalId           String?
  fullName             String
  displayName          String?
  dateOfBirth          DateTime?
  gender               Gender?
  photoUrl             String?
  locale               String
  timezone             String
  language             String
  platformMembershipId String?             @unique
  platformMembership   PlatformMembership? @relation(fields: [platformMembershipId], references: [id])
  tenantMembershipId   String?             @unique
  tenantMembership     TenantMembership?   @relation(fields: [tenantMembershipId], references: [id])

  documents MemberProfileDocument[]
}

// ============== MEMBER PROFILE DOCUMENT ==============

model MemberProfileDocument {
  id              String        @id @unique @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  systemState     SystemState   @default(ACTIVE)
  memberProfileId String
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id])
  type            DocumentType
  value           String
  normalizedValue String

  @@unique([memberProfileId, type])
}

// ============== AUDIT LOG ==============

model AuditLog {
  id         String   @id @unique @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  entityName String
  entityId   String
  ipAddress  String?
  userAgent  String?
  action     String
  before     Json?
  after      Json?

  @@index([tenantId])
  @@index([userId])
  @@index([entityName])
  @@index([entityId])
  @@index([createdAt])
}

// ============== TENANT REGISTRATION ==============

model TenantRegistration {
  id                    String   @id @default(uuid())
  externalRef           String   @unique
  // Valid values defined in RegistrationState enum (backend/src/shared/enums.ts)
  state RegistrationState @default(PENDING)
  paymentId             String?  @unique
  subscriptionId        String?  @unique
  expiresAt             DateTime
  handoffTokenHash      String?  @unique
  handoffTokenExpiresAt DateTime?
  handoffTokenUsedAt    DateTime?
  tenantData            Json
  tenantSiteData        Json
  userData              Json
  identityData          Json
  profileData           Json
  provisionedUserId       String?
  provisionedTenantId     String?
  provisionedMembershipId String?
  provisionedProfileId    String?
  provisionedIdentityId   String?
  provisionedTenantSiteId  String?
  paymentStatus         String?
  paymentStatusDetail   String?
  webhookProcessedAt    DateTime?
  approvedAt            DateTime?
  provisionedAt         DateTime?
  rejectedAt            DateTime?
  expiredAt             DateTime?
  createdAt             DateTime @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @db.Timestamptz(3)

  @@index([state])
  @@index([expiresAt])
  @@index([handoffTokenExpiresAt])
  @@index([subscriptionId])
}

// ============== TENANT SITE ==============

model TenantSite {
  id             String         @id @unique @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  systemState    SystemState    @default(ACTIVE)
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  name           String
  legalName      String
  externalId     String?
  taxId          String         @unique
  siteType       TenantSiteType
  isHeadquarters Boolean        @default(false)

  @@unique([tenantId, taxId])
}

// ============== BILLING ==============

model Plan {
  id                  String   @id @default(uuid())
  type                String   @unique
  name                String
  description         String?
  basePrice           Int
  currency            String   @default("BRL")
  includedUsers       Int
  additionalUserPrice Int?
  maxProducts         Int?
  maxRevisions        Int?
  trialDays           Int?
  features            Json
  isPublic            Boolean  @default(true)
  isActive            Boolean  @default(true)
  // Phase 5: Added for validation logic (allowsAdditionalUsers check in subscription service).
  // This field deviates from EPIC_007 schema which did not originally include it.
  allowsAdditionalUsers Boolean @default(false)

  createdAt           DateTime @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @db.Timestamptz(3)

  @@index([type])
  @@index([isPublic])
  @@index([isActive])
}

model Subscription {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])

  planType               String
  status                 String
  currency               String   @default("BRL")

  provider               String   @default("mercadopago")
  providerSubscriptionId String   @unique
  providerPreapprovalId  String?  @unique
  providerCustomerId     String?

  basePriceSnapshot      Int
  additionalUserPriceSnapshot Int?
  includedUsersSnapshot   Int

  additionalUsers        Int      @default(0)
  currentAmount          Int
  nextBillingAmount      Int?

  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  graceEndsAt            DateTime?
  cancelAtPeriodEnd      Boolean  @default(false)

  failedPaymentCount     Int      @default(0)
  lastPaymentAt          DateTime?
  lastWebhookAt          DateTime?

  createdAt              DateTime @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime @updatedAt @db.Timestamptz(3)

  events                 SubscriptionEvent[]

  @@index([status])
  @@index([planType])
  @@index([currentPeriodEnd])
  @@index([graceEndsAt])
}

model SubscriptionEvent {
  id                   String   @id @default(uuid())
  subscriptionId       String
  subscription         Subscription @relation(fields: [subscriptionId], references: [id])

  providerEventId      String?  @unique
  providerEventType    String
  statusBefore         String?
  statusAfter          String?
  payload              Json

  createdAt            DateTime @default(now()) @db.Timestamptz(3)

  @@index([subscriptionId])
  @@index([providerEventType])
  @@index([createdAt])
}

// ============== BASE CATALOGS (Platform-Scoped) ==============

model BaseAllergen {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  name          String   @unique
  category      String?
  regulatoryRef String?
  sortOrder     Int      @default(0)
}

model BaseNutrient {
  id            String          @id @unique @default(uuid())
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(3)
  name          String          @unique
  unit          NutrientUnit
  category      NutrientCategory
  subcategory   String?
  sortOrder     Int             @default(0)
}

// ============== INGREDIENT DOMAIN ==============

model Allergen {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  category      String?
  regulatoryRef String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  ingredients   IngredientAllergen[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Nutrient {
  id            String          @id @unique @default(uuid())
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(3)
  systemState   SystemState     @default(ACTIVE)
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  name          String
  unit          NutrientUnit
  category      NutrientCategory
  subcategory   String?
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)

  ingredients   IngredientNutrient[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model FunctionalGroup {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  code          String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  ingredients   Ingredient[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Company {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  type          String
  contactInfo   String?
  taxId         String?

  manufacturedIngredients Ingredient[] @relation("ManufacturerIngredients")
  suppliedIngredients     Ingredient[] @relation("SupplierIngredients")

  @@unique([tenantId, taxId])
  @@index([tenantId])
}

model TechnicalInfoSource {
  id            String                  @id @unique @default(uuid())
  createdAt     DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime                @updatedAt @db.Timestamptz(3)
  systemState   SystemState             @default(ACTIVE)
  tenantId      String
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  sourceType    TechnicalInfoSourceType
  referenceName String
  url           String?
  documentRef   String?

  ingredients   Ingredient[]

  @@index([tenantId])
}

model Ingredient {
  id                String                   @id @unique @default(uuid())
  createdAt         DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime                 @updatedAt @db.Timestamptz(3)
  systemState       SystemState              @default(ACTIVE)
  tenantId          String
  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  code              String
  functionalName    String
  commercialName    String?
  saleName          String?
  functionalGroupId String?
  functionalGroup   FunctionalGroup?         @relation(fields: [functionalGroupId], references: [id])
  ingredientFunction IngredientFunctionType
  notes             String?
  manufacturerId    String?
  manufacturer      Company?                 @relation("ManufacturerIngredients", fields: [manufacturerId], references: [id])
  supplierId        String?
  supplier          Company?                 @relation("SupplierIngredients", fields: [supplierId], references: [id])
  technicalSourceId String?
  technicalSource   TechnicalInfoSource?     @relation(fields: [technicalSourceId], references: [id])
  usageIndication   String?
  ingredientsListDesc String?

  allergens         IngredientAllergen[]
  nutrients         IngredientNutrient[]
  regulatoryProfile IngredientRegulatoryProfile?
  labelingProfile   IngredientLabelingProfile?
  technicalProfile  IngredientTechnicalProfile?

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([functionalGroupId])
  @@index([manufacturerId])
  @@index([supplierId])
  @@index([technicalSourceId])
}

model IngredientAllergen {
  id            String               @id @unique @default(uuid())
  createdAt     DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime             @updatedAt @db.Timestamptz(3)
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  ingredientId  String
  ingredient    Ingredient           @relation(fields: [ingredientId], references: [id])
  allergenId    String
  allergen      Allergen             @relation(fields: [allergenId], references: [id])
  relationType  AllergenRelationType

  @@unique([tenantId, ingredientId, allergenId, relationType])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([allergenId])
}

model IngredientNutrient {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  ingredientId  String
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
  nutrientId    String
  nutrient      Nutrient   @relation(fields: [nutrientId], references: [id])
  value         Decimal?

  @@unique([tenantId, ingredientId, nutrientId])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([nutrientId])
}

model IngredientRegulatoryProfile {
  id                    String            @id @unique @default(uuid())
  createdAt             DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime          @updatedAt @db.Timestamptz(3)
  systemState           SystemState       @default(ACTIVE)
  tenantId              String
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  ingredientId          String            @unique
  ingredient            Ingredient        @relation(fields: [ingredientId], references: [id])
  hasRtiq               Boolean           @default(false)
  isGmo                 Boolean           @default(false)
  gmoIngredient         String?
  gmoDonorSpecies       String?
  gmoPercentage         Decimal?
  isIrradiated          Boolean           @default(false)
  irradiatedIngredient  String?
  containsLactose       Boolean           @default(false)
  containsGluten        Boolean           @default(false)
  containsAspartame     Boolean           @default(false)
  flavorOriginType      FlavorOriginType?
  colorantOriginType    ColorantOriginType?

  @@index([tenantId])
  @@index([ingredientId])
}

model IngredientLabelingProfile {
  id                                        String   @id @unique @default(uuid())
  createdAt                                 DateTime @default(now()) @db.Timestamptz(3)
  updatedAt                                 DateTime @updatedAt @db.Timestamptz(3)
  systemState                               SystemState @default(ACTIVE)
  tenantId                                  String
  tenant                                    Tenant   @relation(fields: [tenantId], references: [id])
  ingredientId                              String   @unique
  ingredient                                Ingredient @relation(fields: [ingredientId], references: [id])
  containsAddedSugars                       Boolean  @default(false)
  containsIngredientWithAddedSugars         Boolean  @default(false)
  containsNaturallyOccurringSugarSubstitutes Boolean @default(false)
  usesProcessingThatIncreasesSugars         Boolean  @default(false)
  containsAddedFatsOrOils                   Boolean  @default(false)
  containsButterOrMargarine                 Boolean  @default(false)
  containsDairyCream                        Boolean  @default(false)
  containsIngredientsWithFatsOrCream        Boolean  @default(false)

  @@index([tenantId])
  @@index([ingredientId])
}

model IngredientTechnicalProfile {
  id            String   @id @unique @default(uuid())
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  systemState   SystemState @default(ACTIVE)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  ingredientId  String   @unique
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
  pac           Decimal?
  pod           Decimal?
  totalSolids   Decimal?
  ashContent    Decimal?

  @@index([tenantId])
  @@index([ingredientId])
}
