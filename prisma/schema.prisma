  allergenId    String
  allergen      Allergen_PL          @relation(fields: [allergenId], references: [id])
  relationType  AllergenRelationType

  @@map("IngredientTenantAllergen")
  // Nota: tenantId não incluso no unique — UUIDs são globalmente únicos
  @@unique([ingredientId, allergenId])
  @@index([tenantId])
  @@index([ingredientId])
  @@index([allergenId])
}

model IngredientNutrient_TE {
  id            String          @id @unique @default(uuid())
