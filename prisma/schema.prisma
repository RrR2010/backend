// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  module   = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SystemState {
  ACTIVE
  LOCKED
  HIDDEN
}

model Tenant {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  systemState SystemState @default(ACTIVE)
  name        String

  memberships Membership[]
}

enum PlatformRole {
  ADMIN
  USER
}

model User {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  systemState   SystemState    @default(ACTIVE)
  platformRoles PlatformRole[] @default([USER])
  name          String
  email         String         @unique
  passwordHash  String
  code         String?        @unique

  memberships Membership[]
  sessions    Session[]
}

enum TenantRole {
  ADMIN
  USER
}

model Membership {
  id          String       @id @unique @default(uuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  systemState SystemState  @default(ACTIVE)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  tenantRoles TenantRole[] @default([USER])
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  refreshTokenHash String
  deviceInfo       String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  isRevoked        Boolean   @default(false)

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenHash])
}
