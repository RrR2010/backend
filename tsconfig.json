{
  "include": ["src"],
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@authentication/*": ["src/modules/authentication/*"],
      "@authorization/*": ["src/modules/authorization/*"],
      "@identities/*": ["src/modules/identities/*"],
      "@users/*": ["src/modules/users/*"],
      "@tenants/*": ["src/modules/tenants/*"],
      "@platform-memberships/*": ["src/modules/platform-memberships/*"],
      "@tenant-memberships/*": ["src/modules/tenant-memberships/*"],
      "@member-profiles/*": ["src/modules/member-profiles/*"],
      "@member-profile-documents/*": ["src/modules/member-profile-documents/*"],
      "@tenant-sites/*": ["src/modules/tenant-sites/*"],
      "@audit-logs/*": ["src/modules/audit-logs/*"],
      "@admin/*": ["src/modules/admin/*"],
      "@ingredients/*": ["src/modules/ingredients/*"],
      "@phones/*": ["src/modules/phones/*"],
      "@addresses/*": ["src/modules/addresses/*"],
      "@bootstrap/*": ["src/modules/bootstrap/*"],
      "@billing/*": ["src/modules/billing/*"],
      "@webhook/*": ["src/modules/webhook/*"],
      "@impersonation/*": ["src/modules/impersonation/*"],
      "@formulations/*": ["src/modules/formulations/*"],
      "@products/*": ["src/modules/products/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/@types"]
  }
}
